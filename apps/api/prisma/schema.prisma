  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String            @map("user_id") @db.Uuid
  conversationId  String            @map("conversation_id") @db.Uuid
  rating          Int               // 1 to 5
  comments        String?
  createdAt       DateTime          @default(now()) @map("created_at")

  user            User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("ai_feedback")
}

model AiModelUsage {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?           @map("user_id") @db.Uuid
  provider        String            // "GEMINI", "OPENAI", "CLAUDE"
  model           String
  promptTokens    Int               @default(0) @map("prompt_tokens")
  completionTokens Int              @default(0) @map("completion_tokens")
  estimatedCost   Float             @default(0) @map("estimated_cost")
  createdAt       DateTime          @default(now()) @map("created_at")

  user            User?             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
  @@map("ai_model_usage")
}

model AiError {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?           @map("user_id") @db.Uuid
  toolCallId      String?           @map("tool_call_id") @db.Uuid
  errorMessage    String            @map("error_message")
  stackTrace      String?           @map("stack_trace")
  createdAt       DateTime          @default(now()) @map("created_at")

  @@map("ai_errors")
}

// ====================================================
// EXECUTIVE EMAIL INTEGRATION
// ====================================================

model ExecutiveEmail {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  messageId       String   @unique @map("message_id")
  threadId        String   @map("thread_id")
  sender          String
  subject         String
  date            DateTime
  snippet         String?
  bodyText        String?  @map("body_text")
  hasAttachments  Boolean  @default(false) @map("has_attachments")
  aiSummary       String?  @map("ai_summary")
  aiActions       Json?    @map("ai_actions") // Array of { label, action, color }
  isProcessed     Boolean  @default(false) @map("is_processed")
  isRead          Boolean  @default(false) @map("is_read")
  isImportant     Boolean  @default(false) @map("is_important")
  clientId        String?  @map("client_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  client          Client?  @relation(fields: [clientId], references: [id])

  @@index([isProcessed])
  @@index([isRead])
  @@index([date])
  @@map("executive_emails")
}

// ====================================================
// MODULE: CONTENT STUDIO AI
// ====================================================

enum ContentStatus {
  DRAFT
  GENERATED
  PENDING_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
  REJECTED
}

enum ContentFormat {
  FEED_SQUARE
  FEED_VERTICAL
  STORY
  REEL
  CAROUSEL
}

model ContentCampaign {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  objective       String?
  targetAudience  String?        @map("target_audience")
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  status          String         @default("ACTIVE")
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  posts           ContentPost[]

  @@map("content_campaigns")
}

model ContentStrategy {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String         @default("Sin nombre")
  keywords        String[]       @default([])
  objective       String
  audience        String
  serviceOrProduct String?       @map("service_or_product")
  brandTone       String?        @map("brand_tone")
  pillars         Json?          // Array of pillars
  generatedIdeas  Json?          @map("generated_ideas") // Raw AI output backup
  suggestedSchedule Json?        @map("suggested_schedule")
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")

  createdBy       User?          @relation("StrategyCreator", fields: [createdById], references: [id])
  posts           ContentPost[]  @relation("StrategyPosts")

  @@map("content_strategies")
}

model ContentCalendar {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  period          String         // e.g. "2024-07"
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  posts           ContentPost[]

  @@map("content_calendars")
}

model ContentPost {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  calendarId      String?        @map("calendar_id") @db.Uuid
  campaignId      String?        @map("campaign_id") @db.Uuid
  strategyId      String?        @map("strategy_id") @db.Uuid
  title           String?
  objective       String?
  format          ContentFormat  @default(FEED_SQUARE)
  copyText        String?        @map("copy_text")
  visualPrompt    String?        @map("visual_prompt")
  hashtags        String[]       @default([])
  cta             String?
  scheduledDate   DateTime?      @map("scheduled_date")
  status          ContentStatus  @default(DRAFT)
  assigneeId      String?        @map("assignee_id") @db.Uuid
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  calendar        ContentCalendar? @relation(fields: [calendarId], references: [id])
  campaign        ContentCampaign? @relation(fields: [campaignId], references: [id])
  strategy        ContentStrategy? @relation("StrategyPosts", fields: [strategyId], references: [id])
  
  generatedImages GeneratedImage[]
  approvals       ContentApproval[]
  instagramSchedules InstagramSchedule[]
  instagramPosts  InstagramPost[]

  @@map("content_posts")
}

model BrandKit {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  description     String?
  toneOfVoice     String?        @map("tone_of_voice")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  assets          BrandAsset[]
  colors          BrandColor[]
  fonts           BrandFont[]
  guidelines      BrandGuideline[]

  @@map("brand_kits")
}

model BrandAsset {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  brandKitId      String         @map("brand_kit_id") @db.Uuid
  name            String
  type            String         // logo_primary, logo_white, isotipo, icon, background, template
  fileUrl         String         @map("file_url")
  createdAt       DateTime       @default(now()) @map("created_at")

  brandKit        BrandKit       @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  @@map("brand_assets")
}

model BrandColor {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  brandKitId      String         @map("brand_kit_id") @db.Uuid
  name            String
  hexCode         String         @map("hex_code")
  type            String         // primary, secondary, accent, background
  
  brandKit        BrandKit       @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  @@map("brand_colors")
}

model BrandFont {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  brandKitId      String         @map("brand_kit_id") @db.Uuid
  name            String
  family          String
  url             String?
  usage           String?        // headings, body, buttons
  
  brandKit        BrandKit       @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  @@map("brand_fonts")
}

model BrandGuideline {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  brandKitId      String         @map("brand_kit_id") @db.Uuid
  title           String
  content         String
  
  brandKit        BrandKit       @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  @@map("brand_guidelines")
}

model ContentPerson {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  role            String?
  imageUrl        String         @map("image_url")
  consentStatus   String         @default("PENDING") @map("consent_status") // PENDING, APPROVED, EXPIRED
  consentDocumentUrl String?     @map("consent_document_url")
  allowedUsage    String?        @map("allowed_usage")
  restrictedTopics String?       @map("restricted_topics")
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("content_people")
}

model ContentElement {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String
  type            String         // product, object, uniform, office, vehicle
  imageUrl        String         @map("image_url")
  description     String?
  tags            String[]       @default([])
  allowedUsage    String?        @map("allowed_usage")
  active          Boolean        @default(true)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("content_elements")
}

model GeneratedImage {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  postId          String?        @map("post_id") @db.Uuid
  imageUrl        String         @map("image_url")
  prompt          String
  provider        String         // openai, replicate, etc
  style           String?
  format          ContentFormat?
  isApproved      Boolean        @default(false) @map("is_approved")
  createdById     String?        @map("created_by_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at")

  post            ContentPost?   @relation(fields: [postId], references: [id])
  variations      ImageVariation[]

  @@map("generated_images")
}

model ImageVariation {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  originalImageId   String         @map("original_image_id") @db.Uuid
  imageUrl          String         @map("image_url")
  promptUsed        String         @map("prompt_used")
  createdAt         DateTime       @default(now()) @map("created_at")

  originalImage     GeneratedImage @relation(fields: [originalImageId], references: [id], onDelete: Cascade)

  @@map("image_variations")
}

model InstagramAccount {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  instagramId     String         @unique @map("instagram_id")
  username        String
  profilePicture  String?        @map("profile_picture")
  accessToken     String         @map("access_token")
  tokenExpiresAt  DateTime?      @map("token_expires_at")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  posts           InstagramPost[]
  schedules       InstagramSchedule[]

  @@map("instagram_accounts")
}

model InstagramPost {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  accountId       String         @map("account_id") @db.Uuid
  contentPostId   String?        @map("content_post_id") @db.Uuid
  igMediaId       String?        @unique @map("ig_media_id")
  permalink       String?
  status          String         // PUBLISHED, FAILED
  errorMessage    String?        @map("error_message")
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  account         InstagramAccount @relation(fields: [accountId], references: [id])
  contentPost     ContentPost?   @relation(fields: [contentPostId], references: [id])

  @@map("instagram_posts")
}

model InstagramSchedule {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  accountId       String         @map("account_id") @db.Uuid
  contentPostId   String         @map("content_post_id") @db.Uuid
  scheduledFor    DateTime       @map("scheduled_for")
  status          String         // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  errorMessage    String?        @map("error_message")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  account         InstagramAccount @relation(fields: [accountId], references: [id])
  contentPost     ContentPost    @relation(fields: [contentPostId], references: [id])

  @@map("instagram_schedules")
}

model ContentApproval {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  postId          String         @map("post_id") @db.Uuid
  reviewerId      String         @map("reviewer_id") @db.Uuid
  status          String         // APPROVED, REJECTED
  comments        String?
  createdAt       DateTime       @default(now()) @map("created_at")

  post            ContentPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reviewer        User           @relation(fields: [reviewerId], references: [id])

  @@map("content_approvals")
}

model ContentAnalytics {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  igMediaId       String         @map("ig_media_id")
  reach           Int            @default(0)
  impressions     Int            @default(0)
  likes           Int            @default(0)
  comments        Int            @default(0)
  saves           Int            @default(0)
  engagementRate  Float          @default(0) @map("engagement_rate")
  recordedAt      DateTime       @default(now()) @map("recorded_at")

  @@map("content_analytics")
}

model ContentAiLog {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?        @map("user_id") @db.Uuid
  action          String         // e.g. "generate_image", "create_strategy"
  prompt          String?
  modelUsed       String?        @map("model_used")
  provider        String?
  outputUrl       String?        @map("output_url")
  status          String
  error           String?
  costEstimate    Float?         @map("cost_estimate")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("content_ai_logs")
}

model ContentPublishingLog {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId          String?        @map("user_id") @db.Uuid
  accountId       String?        @map("account_id") @db.Uuid
  postId          String?        @map("post_id") @db.Uuid
  action          String         // "publish", "schedule", "delete"
  status          String
  error           String?
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("content_publishing_logs")
}
