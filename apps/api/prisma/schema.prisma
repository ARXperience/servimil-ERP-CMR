// ====================================================
// SERVIMIL OS · Prisma Schema
// Enterprise ERP/CRM Database
// ====================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgTrgm(map: "pg_trgm"), unaccent]
}

// ====================================================
// ENUMS
// ====================================================

enum UserRole {
  ADMIN
  SUPERVISOR
  FINANCIAL
  LEGAL
  COMMERCIAL
  ADVISOR
  EXECUTIVE
  MARKETING_MANAGER
  DESIGNER
  APPROVER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
  RECONCILED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  NEQUI
  DAVIPLATA
  PSE
  OTHER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum ContractType {
  INDEFINITE
  FIXED_TERM
  PART_TIME
  INTERNSHIP
  FREELANCE
  SERVICE
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  APPROVED
  PAID
  CANCELLED
}

enum CreditStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  PAID_OFF
  DEFAULTED
  RESTRUCTURED
}

enum CreditType {
  PERSONAL
  COMMERCIAL
  MORTGAGE
  VEHICLE
  EDUCATIONAL
  MICROENTERPRISE
}

enum CollectionStatus {
  CURRENT
  DAYS_30
  DAYS_60
  DAYS_90
  DAYS_120_PLUS
  LEGAL
  WRITTEN_OFF
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum LeadSource {
  WHATSAPP
  WEBSITE
  REFERRAL
  CALL
  EMAIL
  SOCIAL_MEDIA
  WALK_IN
  OTHER
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  WHATSAPP_MESSAGE
  VISIT
  TASK
  NOTE
  DOCUMENT
}

enum WhatsappSessionStatus {
  DISCONNECTED
  CONNECTING
  QR_REQUIRED
  CONNECTED
  RECONNECTING
  ERROR
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  REACTION
  TEMPLATE
  INTERACTIVE
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum LegalCaseStatus {
  OPEN
  IN_PROGRESS
  HEARING
  APPEAL
  RESOLVED
  CLOSED
  ARCHIVED
}

enum LegalCaseType {
  COLLECTION
  CONTRACT
  LABOR
  COMMERCIAL
  ADMINISTRATIVE
  CRIMINAL
  CIVIL
  OTHER
}

enum EventPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum DocumentCategory {
  IDENTITY
  FINANCIAL
  LEGAL
  PAYROLL
  CONTRACT
  CREDIT
  GENERAL
  OTHER
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiProvider {
  OPENAI
  GEMINI
  CLAUDE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
  ASSIGN
}

// ====================================================
// CORE: USERS & AUTH
// ====================================================

model User {
  id                String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email             String     @unique
  passwordHash      String     @map("password_hash")
  firstName         String     @map("first_name")
  lastName          String     @map("last_name")
  phone             String?
  avatarUrl         String?    @map("avatar_url")
  role              UserRole   @default(ADVISOR)
  status            UserStatus @default(PENDING_VERIFICATION)
  isEmailVerified   Boolean    @default(false) @map("is_email_verified")
  emailVerifyToken  String?    @map("email_verify_token")
  resetPasswordToken String?   @map("reset_password_token")
  resetPasswordExpiresAt DateTime? @map("reset_password_expires_at")
  lastLoginAt       DateTime?  @map("last_login_at")
  lastLoginIp       String?    @map("last_login_ip")
  mfaEnabled        Boolean    @default(false) @map("mfa_enabled")
  mfaSecret         String?    @map("mfa_secret")
  preferences       Json       @default("{}")
  metadata          Json       @default("{}")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  deletedAt         DateTime?  @map("deleted_at")

  // Relations
  refreshTokens     RefreshToken[]
  assignedLeads     Lead[]         @relation("AssignedAdvisor")
  createdLeads      Lead[]         @relation("CreatedBy")
  activities        Activity[]
  conversations     Conversation[] @relation("AssignedUser")
  whatsappSessions  WhatsappSession[]
  legalCases        LegalCase[]    @relation("AssignedLegal")
  auditLogs         AuditLog[]
  notifications     Notification[]
  documents         Document[]
  payrolls          Payroll[]      @relation("ApprovedBy")
  creditRequests    CreditRequest[] @relation("ReviewedBy")

  // Content Studio
  contentApprovals       ContentApproval[]
  contentStrategies      ContentStrategy[]  @relation("StrategyCreator")

  // AI Hub Relations
  aiConversations        AiConversation[]
  aiExecutionLogs        AiExecutionLog[]
  aiActionConfirmations  AiActionConfirmation[]
  aiMemoryEntries        AiMemoryEntry[]
  aiModelUsages          AiModelUsage[]
  aiFeedbacks            AiFeedback[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token       String   @unique
  userId      String   @map("user_id") @db.Uuid
  deviceInfo  String?  @map("device_info")
  ipAddress   String?  @map("ip_address")
  expiresAt   DateTime @map("expires_at")
  isRevoked   Boolean  @default(false) @map("is_revoked")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ====================================================
// CLIENTS & CONTACTS (CRM Core)
// ====================================================

model Client {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  documentType    String    @map("document_type") // CC, NIT, CE, TI
  documentNumber  String    @unique @map("document_number")
  firstName       String?   @map("first_name")
  lastName        String?   @map("last_name")
  businessName    String?   @map("business_name")
  email           String?
  phone           String?
  phone2          String?
  address         String?
  city            String?
  department      String?
  country         String    @default("Colombia")
  birthDate       DateTime? @map("birth_date")
  occupation      String?
  monthlyIncome   Decimal?  @map("monthly_income") @db.Decimal(15, 2)
  riskScore       Int?      @map("risk_score") @db.SmallInt // 0-100
  tags            String[]  @default([])
  notes           String?
  isActive        Boolean   @default(true) @map("is_active")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  leads           Lead[]
  credits         CreditRequest[]
  contacts        Contact[]
  conversations   Conversation[]
  legalCases      LegalCase[]
  documents       Document[]
  transactions    Transaction[]
  employees       Employee[]
  payrolls        Payroll[]
  executiveEmails ExecutiveEmail[]

  @@index([documentNumber])
  @@index([phone])
  @@index([email])
  @@map("clients")
}

model Contact {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clientId    String   @map("client_id") @db.Uuid
  name        String
  relationship String?  // spouse, parent, reference, etc.
  phone       String?
  email       String?
  address     String?
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

// ====================================================
// MODULE 1: FINANCE & TREASURY
// ====================================================

model Account {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  code          String   @unique
  type          String   // bank, cash, credit, investment
  bankName      String?  @map("bank_name")
  bankAccount   String?  @map("bank_account")
  initialBalance Decimal @default(0) @map("initial_balance") @db.Decimal(15, 2)
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(15, 2)
  currency      String   @default("COP")
  isActive      Boolean  @default(true) @map("is_active")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  transactionsFrom Transaction[] @relation("FromAccount")
  transactionsTo   Transaction[] @relation("ToAccount")
  reconciliations  BankReconciliation[]

  @@map("accounts")
}

model Category {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  code        String    @unique
  type        TransactionType
  parentId    String?   @map("parent_id") @db.Uuid
  color       String?
  icon        String?
  isSystem    Boolean   @default(false) @map("is_system")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  transactions Transaction[]

  @@map("categories")
}

model Transaction {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reference       String            @unique
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal           @db.Decimal(15, 2)
  currency        String            @default("COP")
  exchangeRate    Decimal?          @map("exchange_rate") @db.Decimal(10, 6)
  description     String
  notes           String?
  paymentMethod   PaymentMethod?    @map("payment_method")
  fromAccountId   String?           @map("from_account_id") @db.Uuid
  toAccountId     String?           @map("to_account_id") @db.Uuid
  categoryId      String?           @map("category_id") @db.Uuid
  clientId        String?           @map("client_id") @db.Uuid
  creditId        String?           @map("credit_id") @db.Uuid
  payrollId       String?           @map("payroll_id") @db.Uuid
  transactionDate DateTime          @map("transaction_date")
  reconciledAt    DateTime?         @map("reconciled_at")
  tags            String[]          @default([])
  attachments     String[]          @default([])
  metadata        Json              @default("{}")
  aiCategory      String?           @map("ai_category")
  aiConfidence    Float?            @map("ai_confidence")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  fromAccount     Account?          @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount       Account?          @relation("ToAccount", fields: [toAccountId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  client          Client?           @relation(fields: [clientId], references: [id])
  credit          CreditRequest?    @relation(fields: [creditId], references: [id])
  payroll         Payroll?          @relation(fields: [payrollId], references: [id])

  @@index([transactionDate])
  @@index([type, status])
  @@index([clientId])
  @@map("transactions")
}

model BankReconciliation {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  period          String   // "2024-01"
  bankBalance     Decimal  @map("bank_balance") @db.Decimal(15, 2)
  bookBalance     Decimal  @map("book_balance") @db.Decimal(15, 2)
  difference      Decimal  @db.Decimal(15, 2)
  isReconciled    Boolean  @default(false) @map("is_reconciled")
  reconciledAt    DateTime? @map("reconciled_at")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  account         Account  @relation(fields: [accountId], references: [id])

  @@unique([accountId, period])
  @@map("bank_reconciliations")
}

model Budget {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  period      String   // "2024-Q1", "2024-01"
  type        String   // monthly, quarterly, annual
  totalAmount Decimal  @map("total_amount") @db.Decimal(15, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  items       BudgetItem[]

  @@map("budgets")
}

model BudgetItem {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  budgetId    String   @map("budget_id") @db.Uuid
  categoryId  String?  @map("category_id") @db.Uuid
  name        String
  planned     Decimal  @db.Decimal(15, 2)
  actual      Decimal  @default(0) @db.Decimal(15, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  budget      Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("budget_items")
}

// ====================================================
// MODULE 2: PAYROLL & COMPLIANCE
// ====================================================

model Department {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String
  code        String     @unique
  managerId   String?    @map("manager_id") @db.Uuid
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  employees   Employee[]

  @@map("departments")
}

model Position {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title       String
  code        String     @unique
  baseSalary  Decimal    @map("base_salary") @db.Decimal(15, 2)
  isActive    Boolean    @default(true) @map("is_active")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  employees   Employee[]

  @@map("positions")
}

model Employee {
  id                String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clientId          String?        @map("client_id") @db.Uuid
  employeeCode      String         @unique @map("employee_code")
  departmentId      String?        @map("department_id") @db.Uuid
  positionId        String?        @map("position_id") @db.Uuid
  contractType      ContractType   @map("contract_type")
  status            EmployeeStatus @default(ACTIVE)
  baseSalary        Decimal        @map("base_salary") @db.Decimal(15, 2)
  transportAllowance Decimal       @default(0) @map("transport_allowance") @db.Decimal(15, 2)
  bankName          String?        @map("bank_name")
  bankAccount       String?        @map("bank_account")
  bankAccountType   String?        @map("bank_account_type") // savings, checking
  eps               String?        // Health provider
  afp               String?        // Pension fund
  arl               String?        // Labor risk
  ccf               String?        // Family compensation
  hireDate          DateTime       @map("hire_date")
  terminationDate   DateTime?      @map("termination_date")
  terminationReason String?        @map("termination_reason")
  emergencyContact  Json?          @map("emergency_contact")
  metadata          Json           @default("{}")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  client            Client?        @relation(fields: [clientId], references: [id])
  department        Department?    @relation(fields: [departmentId], references: [id])
  position          Position?      @relation(fields: [positionId], references: [id])
  payrollItems      PayrollItem[]
  novelties         PayrollNovelty[]

  @@map("employees")
}

model Payroll {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  period        String        // "2024-01"
  periodType    String        @map("period_type") // monthly, biweekly
  status        PayrollStatus @default(DRAFT)
  totalGross    Decimal       @default(0) @map("total_gross") @db.Decimal(15, 2)
  totalDeductions Decimal     @default(0) @map("total_deductions") @db.Decimal(15, 2)
  totalNet      Decimal       @default(0) @map("total_net") @db.Decimal(15, 2)
  totalEmployees Int          @default(0) @map("total_employees")
  approvedById  String?       @map("approved_by_id") @db.Uuid
  approvedAt    DateTime?     @map("approved_at")
  paidAt        DateTime?     @map("paid_at")
  notes         String?
  clientId      String?       @map("client_id") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  approvedBy    User?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  client        Client?       @relation(fields: [clientId], references: [id])
  items         PayrollItem[]
  transactions  Transaction[]

  @@unique([period, clientId])
  @@map("payrolls")
}

model PayrollItem {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  payrollId           String   @map("payroll_id") @db.Uuid
  employeeId          String   @map("employee_id") @db.Uuid
  baseSalary          Decimal  @map("base_salary") @db.Decimal(15, 2)
  transportAllowance  Decimal  @default(0) @map("transport_allowance") @db.Decimal(15, 2)
  workedDays          Int      @default(30) @map("worked_days")
  extraHours          Decimal  @default(0) @map("extra_hours") @db.Decimal(8, 2)
  extraHoursValue     Decimal  @default(0) @map("extra_hours_value") @db.Decimal(15, 2)
  commissions         Decimal  @default(0) @db.Decimal(15, 2)
  bonuses             Decimal  @default(0) @db.Decimal(15, 2)
  grossSalary         Decimal  @map("gross_salary") @db.Decimal(15, 2)
  // Social security (employee contributions)
  healthEmployee      Decimal  @default(0) @map("health_employee") @db.Decimal(15, 2)
  pensionEmployee     Decimal  @default(0) @map("pension_employee") @db.Decimal(15, 2)
  // Social security (employer contributions)
  healthEmployer      Decimal  @default(0) @map("health_employer") @db.Decimal(15, 2)
  pensionEmployer     Decimal  @default(0) @map("pension_employer") @db.Decimal(15, 2)
  arlEmployer         Decimal  @default(0) @map("arl_employer") @db.Decimal(15, 2)
  ccfEmployer         Decimal  @default(0) @map("ccf_employer") @db.Decimal(15, 2)
  // Deductions
  retentionIncome     Decimal  @default(0) @map("retention_income") @db.Decimal(15, 2)
  otherDeductions     Decimal  @default(0) @map("other_deductions") @db.Decimal(15, 2)
  totalDeductions     Decimal  @map("total_deductions") @db.Decimal(15, 2)
  netSalary           Decimal  @map("net_salary") @db.Decimal(15, 2)
  // Provisions
  cesantias           Decimal  @default(0) @db.Decimal(15, 2)
  interestCesantias   Decimal  @default(0) @map("interest_cesantias") @db.Decimal(15, 2)
  prima               Decimal  @default(0) @db.Decimal(15, 2)
  vacaciones          Decimal  @default(0) @db.Decimal(15, 2)
  payStubUrl          String?  @map("pay_stub_url")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  payroll             Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee            Employee @relation(fields: [employeeId], references: [id])

  @@unique([payrollId, employeeId])
  @@map("payroll_items")
}

model PayrollNovelty {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  type        String   // absence, disability, vacation, bonus, deduction, extra_hours
  description String
  amount      Decimal? @db.Decimal(15, 2)
  days        Int?
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  isApproved  Boolean  @default(false) @map("is_approved")
  period      String   // "2024-01"
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  employee    Employee @relation(fields: [employeeId], references: [id])

  @@map("payroll_novelties")
}

// ====================================================
// MODULE 3: CREDIT & PORTFOLIO
// ====================================================

model CreditRequest {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requestNumber     String          @unique @map("request_number")
  clientId          String          @map("client_id") @db.Uuid
  type              CreditType      @default(PERSONAL)
  status            CreditStatus    @default(DRAFT)
  requestedAmount   Decimal         @map("requested_amount") @db.Decimal(15, 2)
  approvedAmount    Decimal?        @map("approved_amount") @db.Decimal(15, 2)
  disbursedAmount   Decimal?        @map("disbursed_amount") @db.Decimal(15, 2)
  interestRate      Decimal?        @map("interest_rate") @db.Decimal(8, 4) // annual %
  term              Int?            // months
  paymentFrequency  String?         @map("payment_frequency") // monthly, biweekly, weekly
  purpose           String?
  collateral        String?
  riskScore         Int?            @map("risk_score") @db.SmallInt // 0-100
  riskLevel         String?         @map("risk_level") // low, medium, high, critical
  reviewedById      String?         @map("reviewed_by_id") @db.Uuid
  reviewedAt        DateTime?       @map("reviewed_at")
  disbursedAt       DateTime?       @map("disbursed_at")
  expectedEndDate   DateTime?       @map("expected_end_date")
  rejectionReason   String?         @map("rejection_reason")
  notes             String?
  aiAnalysis        Json?           @map("ai_analysis")
  metadata          Json            @default("{}")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  client            Client          @relation(fields: [clientId], references: [id])
  reviewedBy        User?           @relation("ReviewedBy", fields: [reviewedById], references: [id])
  installments      CreditInstallment[]
  transactions      Transaction[]
  documents         Document[]
  collections       CollectionAction[]

  @@index([clientId])
  @@index([status])
  @@map("credit_requests")
}

model CreditInstallment {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  creditId          String           @map("credit_id") @db.Uuid
  installmentNumber Int              @map("installment_number")
  dueDate           DateTime         @map("due_date")
  principalAmount   Decimal          @map("principal_amount") @db.Decimal(15, 2)
  interestAmount    Decimal          @map("interest_amount") @db.Decimal(15, 2)
  totalAmount       Decimal          @map("total_amount") @db.Decimal(15, 2)
  paidAmount        Decimal          @default(0) @map("paid_amount") @db.Decimal(15, 2)
  paidAt            DateTime?        @map("paid_at")
  daysOverdue       Int              @default(0) @map("days_overdue")
  penaltyAmount     Decimal          @default(0) @map("penalty_amount") @db.Decimal(15, 2)
  collectionStatus  CollectionStatus @default(CURRENT) @map("collection_status")
  isPaid            Boolean          @default(false) @map("is_paid")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

