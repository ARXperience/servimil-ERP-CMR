  notes           String?
  status          String    @default("open") // open, resolved, archived
  funnelStage     String    @default("NUEVO") @map("funnel_stage") // NUEVO, INTERESADO, NEGOCIANDO, CLIENTE, DESCARTADO
  sentimentScore  Float?    @map("sentiment_score")
  aiSummary       String?   @map("ai_summary")
  lastAiAnalysisAt DateTime? @map("last_ai_analysis_at")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
