# ==========================================
# SERVIMIL OS - Environment Variables
# ==========================================

# ---- APP ----
NODE_ENV=development
APP_NAME=SERVIMIL OS
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# ---- API ----
API_PORT=3001
API_URL=http://localhost:3001
API_PREFIX=api
API_VERSION=v1

# ---- DATABASE (PostgreSQL) ----
DATABASE_URL=postgresql://servimil:servimil_pass@localhost:5432/servimil_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=servimil_db
DATABASE_USER=servimil
DATABASE_PASSWORD=servimil_pass
DATABASE_SSL=false

# ---- SUPABASE ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- REDIS ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ---- AI PROVIDERS ----
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# AI Gateway default provider
AI_DEFAULT_PROVIDER=openai

# ---- OCR ----
GOOGLE_CLOUD_VISION_KEY=your-google-cloud-vision-key
OCR_PROVIDER=tesseract
# Options: tesseract | google_vision | gemini | openai

# ---- WHATSAPP (Baileys) ----
WHATSAPP_SESSION_PATH=./sessions/whatsapp
WHATSAPP_MAX_SESSIONS=10
WHATSAPP_RECONNECT_INTERVAL=5000

# ---- SMTP (Email) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=SERVIMIL OS <noreply@servimil.com>

# ---- AWS S3 / Cloudflare R2 (File Storage) ----
STORAGE_PROVIDER=local
# Options: local | s3 | r2
S3_BUCKET=servimil-files
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://your-r2-endpoint.r2.cloudflarestorage.com

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,https://app.servimil.com

# ---- RATE LIMITING ----
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ---- ENCRYPTION ----
ENCRYPTION_KEY=your-32-char-encryption-key-here!

# ---- REPORTS / PDF ----
PDF_FONT_URL=https://fonts.gstatic.com

# ---- FRONTEND (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=SERVIMIL OS
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- WEBHOOKS ----
WEBHOOK_SECRET=your-webhook-secret-key

# ---- LOGGING ----
LOG_LEVEL=debug
LOG_FORMAT=json
